@model IEnumerable<ApexOMS_Web.Models.DashboardData>
@* Only show this button if the user is NOT in the IB department *@
@* @if (Context.Session.GetString("UserRole") != "IB")
{
    <a href="/DashboardData.cs/Create" class="btn btn-primary">+ Add New</a>
} *@

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-info fw-bold">Production Tracking Dashboard</h2>
        @if (Context.Session.GetString("UserRole") != "IB")
        {
            <a href="/Dashboard/Create" class="btn btn-info text-white">+ Add New Record</a>
        }
        
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-info">
                    <tr>
                        <th>Order #</th>
                        <th>Shop Order</th>
                        <th>Customer</th>
                        <th>Sample Order</th>
                        <th>Tech Sheet Status</th>
                        <th>Knife Status</th>
                        <th>Total Order Quantity</th>
                        <th>Shipment Quantity</th>
                        <th>Customer Delivery Date</th>
                        <th>Product Delivery Date</th>
                        <th>Shipment Date</th>
                        
                        <th>Status</th>
                        <th>Picture</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.shop_order_number</td>
                            <td>@item.shop_no_generated</td>
                            <td>@item.cust_name</td>
                            <td>@item.sample_order_no</td>
                            <td>@item.tech_sheet_status</td>
                            <td>@item.knife_status</td>
                            <td>@item.order_qty</td>
                            <td>@item.shipment_quantity</td>
                            <td>@item.cd_date?.ToShortDateString()</td>
                            <td>@item.pd_date?.ToShortDateString()</td>
                            <td>@item.shipment_date?.ToShortDateString()</td>
                            
                            @* <td><span class="badge bg-secondary">@item.approval</span></td> *@
                            <td>
                                @if (item.approval == "Approved")
                                {
                                    <span class="badge bg-success px-3 shadow-sm">
                                        <i class="bi bi-check-circle me-1"></i> Approved
                                    </span>
                                }
                                else if (item.approval == "Pending")
                                {
                                    <span class="badge bg-warning text-dark px-3 shadow-sm">
                                        <i class="bi bi-clock me-1"></i> Pending
                                    </span>
                                }
                                else if (item.approval == "Rejected" )
                                {
                                    <span class="badge bg-danger px-3 shadow-sm">
                                        <i class="bi bi-x-circle me-1"></i> Rejected
                                    </span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.image_path))
                                {
                                    <img src="@item.image_path" alt="Shoe" style="width:60px; height:60px; object-fit:cover; border-radius:5px;" />
                                }
                                else
                                {
                                    <span class="text-muted small">No Image</span>
                                }
                            </td>
                            <td>
                                <a href="/Dashboard/Edit/@item.shop_order_number" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>