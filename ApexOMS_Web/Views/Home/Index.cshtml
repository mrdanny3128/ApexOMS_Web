@{
    ViewData["Title"] = "Apex Dashboard";
}

<div class="container mt-5 text-center">
    <h1 class="display-4 fw-bold text-primary mb-3">Apex Order Management</h1>
    <p class="lead text-muted mb-5">Welcome to the central production portal.</p>

    <div class="row justify-content-center">
        <div class="col-md-4 mb-4">
            <div class="card shadow border-0 h-100 p-3">
                <div class="card-body">
                    <h3 class="card-title text-success">Inventory</h3>
                    <p class="card-text text-muted">View and add new production orders.</p>
                    <a href="/Inventory/Index" class="btn btn-success px-4">Open Inventory</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow border-0 h-100 p-3">
                <div class="card-body">
                    <h3 class="card-title text-primary">Articles</h3>
                    <p class="card-text text-muted">Manage shoe articles and last molds.</p>
                    <a href="/Article/Index" class="btn btn-primary px-4">Open Master</a>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="col-md-4 mb-4">
    <div class="card shadow border-0 h-100 p-3">
        <div class="card-body text-center">
            <h3 class="card-title text-info">Production Tracking</h3>
            <p class="card-text text-muted">Monitor CD/PD dates and shipment status.</p>
            <a href="/Dashboard/Index" class="btn btn-info text-white px-4">Open Dashboard</a>
        </div>
    </div>
</div>
@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("UserRole");
}

<div class="container mt-5">
    <h1>Welcome, @Context.Session.GetString("UserName")</h1>
    <hr />

    @if (role == "SuperAdmin")
    {
        <partial name="_SuperAdminDash" />
    }
    else if (role == "DesignLab")
    {
        <partial name="_DesignLabDash" />
    }
    else
    {
        <partial name="_IBDash" />
    }
</div>