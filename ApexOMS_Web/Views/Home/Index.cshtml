@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("UserRole");
}

<div class="container mt-5">

    @* --- UPPER PORTION: Only show for Super Admin --- *@
    @if (role == "SuperAdmin")
    {

        @* --- Super Admin Row: 4 Equal Cards --- *@
        <div class="row justify-content-center g-4 mb-5">
            <div class="col-md-3">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center p-4">
                        <h3 class="text-success fw-bold">Inventory</h3>
                        <p class="small text-muted">View and add new production orders.</p>
                        <a href="/Inventory/Index" class="btn btn-success w-100 mt-2">Open Inventory</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center p-4">
                        <h3 class="text-primary fw-bold">Articles</h3>
                        <p class="small text-muted">Manage shoe articles and last molds.</p>
                        <a href="/Article/Index" class="btn btn-primary w-100 mt-2">Open Master</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center p-4">
                        <h3 class="text-info fw-bold">Production Tracking</h3>
                        <p class="small text-muted">Monitor CD/PD dates and status.</p>
                        <a href="/Dashboard/Index" class="btn btn-info text-white w-100 mt-2">Open Dashboard</a>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center p-4">
                        <h3 class="text-info fw-bold">Sample Order</h3>
                        <p class="small text-muted">Manange Samples for Order</p>
                        <a href="/SampleOrder/Index" class="btn btn-info text-white w-100 mt-2">Open Sample Order</a>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card shadow border-0 h-100">
                    <div class="card-body text-center p-4">
                        <h3 class="text-dark fw-bold">Bill of Materials</h3>
                        <p class="small text-muted">Manage materials and shoe recipes.</p>
                        <a href="/Bom/Index" class="btn btn-dark w-100 mt-2">Open BOM</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="row justify-content-center mt-4">
            <div class="col-md-4">
                <div class="card shadow border-0 border-top border-danger border-5 h-100">
                    <div class="card-body text-center p-4">
                        <i class="bi bi-shield-lock-fill text-danger display-5"></i>
                        <h3 class="text-danger fw-bold mt-2">User Access Control</h3>
                        <p class="small text-muted">Approve new registrations and assign roles (IB, Design Lab, Admin)</p>
                        <a href="/Account/UserList" class="btn btn-danger w-100 mt-2 fw-bold">Manage Users & Approvals</a>
                    </div>
                </div>
            </div>
        </div>
        <hr />
    }

    @* --- LOWER PORTION: Role-Based Content --- *@
    <div class="mt-4">
        @if (role == "SuperAdmin")
        {
            @* SuperAdmin can see everything, or a specific admin view *@
            <h3>Super Admin Control Panel</h3>
            @* Add admin specific links here *@
        }
        else if (role == "DesignLab")
        {
            @* This is what shows for DL users now *@
            <partial name="_DesignLabDash" />
        }
        else if (role == "IB")
        {
            <partial name="_IBDash" />
        }
    </div>
</div>









