
<style>
    :root {
        --admin-slate: #2d3436;
        --admin-danger: #d63031;
    }

    /* Full Width Fluid Layout */
    .admin-container {
        max-width: 100% !important;
        padding: 2rem 3rem;
    }

    /* Command Center Header */
    .admin-banner {
        background: var(--admin-slate);
        color: white;
        border-radius: 15px;
        padding: 40px;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        border-left: 10px solid var(--admin-danger);
    }

    /* Group Titles */
    .section-divider {
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #636e72;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
    }

        .section-divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: #dee2e6;
            margin-left: 20px;
        }

    /* Admin Action Cards */
    .admin-card {
        background: #fff;
        backdrop-filter: blur(10px);
        border: 1px solid #edf2f7;
        border-radius: 12px;
        padding: 30px;
        height: 100%;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        text-decoration: none !important;
        display: block;
    }

        .admin-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

    .admin-icon-box {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 20px;
        transition: 0.3s;
    }

    /* --- COLOR CLASSES --- */

    /* Security - Red */
    .admin-security {
        background-color: rgba(214, 48, 49, 0.1);
        color: var(--admin-danger);
    }

    .admin-card:hover .admin-security {
        background-color: var(--admin-danger);
        color: white;
    }

    .admin-card:hover {
        border-color: var(--admin-danger);
    }

    /* Inventory - Green */
    .admin-inventory {
        background-color: rgba(25, 135, 84, 0.1);
        color: #198754;
    }

    .admin-card:hover:has(.admin-inventory) {
        border-color: #198754;
    }

    .admin-card:hover .admin-inventory {
        background-color: #198754;
        color: white;
    }

    /* Articles - Orange */
    .admin-article {
        background-color: rgba(255, 193, 7, 0.1);
        color: #ffc107;
    }

    .admin-card:hover:has(.admin-article) {
        border-color: #ffc107;
    }

    .admin-card:hover .admin-article {
        background-color: #ffc107;
        color: white;
    }

    /* BOM - Dark */
    .admin-bom {
        background-color: rgba(33, 37, 41, 0.1);
        color: #212529;
    }

    .admin-card:hover:has(.admin-bom) {
        border-color: #212529;
    }

    .admin-card:hover .admin-bom {
        background-color: #212529;
        color: white;
    }

    /* Dashboard - Cyan */
    .admin-dash {
        background-color: rgba(13, 202, 240, 0.1);
        color: #0dcaf0;
    }

    .admin-card:hover:has(.admin-dash) {
        border-color: #0dcaf0;
    }

    .admin-card:hover .admin-dash {
        background-color: #0dcaf0;
        color: white;
    }

    /* Sample - Blue */
    .admin-sample {
        background-color: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
    }

    .admin-card:hover:has(.admin-sample) {
        border-color: #0d6efd;
    }

    .admin-card:hover .admin-sample {
        background-color: #0d6efd;
        color: white;
    }
</style>
@using Microsoft.AspNetCore.Http
@{
    var role = Context.Session.GetString("UserRole");
}


<div class="container mt-5">
    <h1>Hello, @Context.Session.GetString("UserName")</h1>
    <hr />

    @if (role == "SuperAdmin")
    {
        <partial name="_SuperAdminDash" />
    }
   
</div>


    @* --- LOWER PORTION: Role-Based Content --- *@
    <div class="mt-4">
        @if (role == "SuperAdmin")
        {
            @* SuperAdmin can see everything, or a specific admin view *@
            @* <h3>Super Admin Control Panel</h3> *@
            @* Add admin specific links here *@
        }
        else if (role == "DesignLab")
        {
            @* This is what shows for DL users now *@
            <partial name="_DesignLabDash" />
        @* <h3>Design Lab Control Panel</h3> *@
        }
        else if (role == "IB")
        {
            <partial name="_IBDash" />
        @* <h3>International Business Control Panel</h3> *@
        }
    </div>


@section Scripts {
    <script>
        $(document).ready(function () {
            // "myTable" must match the ID you gave your <table> tag
            $('#myTable').DataTable({
                "paging": true,
                "lengthChange": true,
                "searching": true, // This enables the search bar
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
                "language": {
                    "search": "", // Removes the "Search:" label for a cleaner look
                    "searchPlaceholder": "Search anything..." // Text inside the bar
                }
            });
        });
    </script>
}







