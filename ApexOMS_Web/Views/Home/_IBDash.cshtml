<style>
    /* Content Wrapper */
    .ib-wrapper {
        display: flex;
        min-height: 85vh;
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    }

    /* Side Navigation */
    .ib-sidebar {
        width: 280px;
        background: #2c3e50; /* Dark Executive Blue */
        padding: 30px 20px;
        display: flex;
        flex-direction: column;
    }

    .ib-sidebar-title {
        color: #ecf0f1;
        font-weight: 800;
        font-size: 1.2rem;
        letter-spacing: 1px;
        margin-bottom: 5px;
    }

    .ib-sidebar-subtitle {
        color: #bdc3c7;
        font-size: 0.75rem;
        text-transform: uppercase;
        margin-bottom: 40px;
    }

    .ib-nav-link {
        color: #bdc3c7;
        text-decoration: none;
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        transition: 0.3s;
        font-weight: 500;
    }

        .ib-nav-link i {
            font-size: 1.2rem;
            margin-right: 15px;
        }

        .ib-nav-link:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            transform: translateX(5px);
        }

    /* Main Content Area */
    .ib-main {
        flex: 1;
        padding: 50px;
        background: #fff;
    }

    .ib-welcome-card {
        border-left: 5px solid #2980b9;
        padding-left: 20px;
        margin-bottom: 40px;
    }

    .ib-info-box {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 25px;
        margin-top: 20px;
        border: 1px dashed #dee2e6;
    }
</style>

<div class="container-fluid mt-4 px-5">
    <div class="ib-wrapper shadow-lg">
        <div class="ib-sidebar">
            <div class="ib-sidebar-title text-uppercase">IB Portal</div>
            <div class="ib-sidebar-subtitle">Analytics & Reporting</div>

            <nav class="mt-4">
