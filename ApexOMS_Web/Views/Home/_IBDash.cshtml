                    <i class="bi bi-file-earmark-spreadsheet"></i> Master BOM
                </a>
                <a href="/Article/Index" class="ib-nav-link">
                    <i class="bi bi-search"></i> Article Search
                </a>
                <a href="/Dashboard/Index" class="ib-nav-link">
                    <i class="bi bi-display"></i> Live Dashboard
                </a>
                <a href="/SampleOrder/Index" class="ib-nav-link">
                    <i class="bi bi-box-seam"></i> Sample Tracking
                </a>
            </nav>

            <div class="mt-auto pt-5">
                <p class="text-muted small px-3">Logged in as IB Department</p>
            </div>
        </div>

        <div class="ib-main">
            <div class="ib-welcome-card">
                <h2 class="fw-bold">International Business View</h2>
                <p class="text-secondary mb-0">Authorized Personnel: Read-Only Access</p>
            </div>

            <div class="row">
                <div class="col-md-8">
                    <h5 class="fw-bold mb-3">Quick Navigation</h5>
                    <p class="text-muted">Welcome to the central IB operations hub. Select a module from the left sidebar to view real-time production and inventory analytics. All data is synchronized with the Apex factory floor.</p>

                    <div class="ib-info-box">
                        <h6 class="fw-bold text-primary"><i class="bi bi-info-circle me-2"></i>System Note</h6>
                        <p class="small mb-0 text-dark">You have <strong>Viewer Rights</strong>. You can export data to Excel but cannot modify production records.</p>
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-center justify-content-center">
                    <img src="~/images/apex_logo.png" style="width: 150px; opacity: 0.2; filter: grayscale(100%);" />
                </div>
            </div>
        </div>
    </div>
</div> *@


@{
    ViewData["Title"] = "IB Analytics Portal";
}

<style>
    /* 1. Base IB Card - Border hidden by default */
    .module-card {
        background: #fff;
        border: 2px solid transparent !important;
        border-radius: 12px;
        transition: all 0.3s ease-in-out;
        text-decoration: none !important;
        display: block;
        height: 100%;
        padding: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

        /* 2. Hover Transitions */
        .module-card:hover {
            transform: translateY(-8px);
            background: #fff;
        }

    /* Icon Box Base */
    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 0;
        transition: all 0.3s ease;
    }

    /* --- IB SPECIFIC COLORS --- */

    /* Inventory Reports - Green */
    .icon-inventory {
        background-color: rgba(25, 135, 84, 0.1);
        color: #198754;
    }

    .module-card:hover:has(.icon-inventory) {
        border-color: #198754 !important;
        box-shadow: 0 10px 20px rgba(25, 135, 84, 0.1);
    }

    .module-card:hover .icon-inventory {
        background-color: #198754;
        color: #fff;
    }

    /* BOM View - Dark/Slate */
    .icon-bom {
        background-color: rgba(33, 37, 41, 0.1);
        color: #212529;
    }

    .module-card:hover:has(.icon-bom) {
        border-color: #212529 !important;
        box-shadow: 0 10px 20px rgba(33, 37, 41, 0.1);
    }

    .module-card:hover .icon-bom {
        background-color: #212529;
        color: #fff;
    }

    /* Article Search - Orange */
    .icon-article {
        background-color: rgba(255, 193, 7, 0.1);
        color: #ffc107;
    }

    .module-card:hover:has(.icon-article) {
        border-color: #ffc107 !important;
        box-shadow: 0 10px 20px rgba(255, 193, 7, 0.1);
    }

    .module-card:hover .icon-article {
        background-color: #ffc107;
        color: #fff;
    }

    /* Production Tracking - Cyan */
    .icon-dash {
        background-color: rgba(13, 202, 240, 0.1);
        color: #0dcaf0;
    }

    .module-card:hover:has(.icon-dash) {
        border-color: #0dcaf0 !important;
        box-shadow: 0 10px 20px rgba(13, 202, 240, 0.1);
    }

    .module-card:hover .icon-dash {
        background-color: #0dcaf0;
        color: #fff;
    }

    /* Sample Tracking - Blue */
    .icon-sample {
        background-color: rgba(13, 110, 253, 0.1);
        color: #0d6efd;
    }

    .module-card:hover:has(.icon-sample) {
        border-color: #0d6efd !important;
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.1);
    }

    .module-card:hover .icon-sample {
        background-color: #0d6efd;
        color: #fff;
    }

    .ib-title {
        color: #2d3436;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 4px;
    }

    .ib-desc {
        color: #636e72;
        font-size: 0.85rem;
        margin-bottom: 0;
    }
</style>

