@{
    ViewData["Title"] = "IB Analytics Portal";
}

<style>
    /* 1. Page Header with Glassmorphism */
    .ib-header {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        padding: 30px;
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: 0 8px 32px rgba(0,0,0,0.05);
        margin-bottom: 40px;
    }

    /* 2. Action Tiles */
    .ib-tile {
        background: #fff;
        border-radius: 12px;
        padding: 25px;
        text-decoration: none !important;
        display: flex;
        align-items: center;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        border: 1px solid #edf2f7;
        position: relative;
        overflow: hidden;
    }

        .ib-tile:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08);
            border-color: #3182ce;
        }

    /* 3. Icon Accent */
    .tile-icon {
        width: 55px;
        height: 55px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-right: 20px;
        background: #f7fafc;
        color: #4a5568;
        transition: 0.3s;
    }

    .ib-tile:hover .tile-icon {
        background: #3182ce;
        color: #fff;
    }

    .tile-content h6 {
        margin-bottom: 2px;
        color: #2d3748;
        font-weight: 700;
    }

    .tile-content p {
        margin-bottom: 0;
        font-size: 0.8rem;
        color: #718096;
    }

    /* 4. "Live" Indicator */
    .live-dot {
        height: 8px;
        width: 8px;
        background-color: #48bb78;
        border-radius: 50%;
        display: inline-block;
        margin-right: 5px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(72, 187, 120, 0.7);
        }

        70% {
            transform: scale(1);
            box-shadow: 0 0 0 10px rgba(72, 187, 120, 0);
        }

        100% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(72, 187, 120, 0);
        }
    }
</style>

<div class="container py-5">
    <div class="ib-header d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-dark mb-1">IB Operations Console</h2>
            <p class="text-muted mb-0 small">
                <span class="live-dot"></span> System Online | Ready-Only Environment
            </p>
        </div>
        <div class="text-end">
            <img src="~/images/apex_logo.png" style="width: 100px;" />
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <a href="/Inventory/Index" class="ib-tile h-100">
                <div class="tile-icon"><i class="bi bi-bar-chart-line"></i></div>
                <div class="tile-content">
                    <h4>Inventory Reports</h4>
                    <p>Analyze current stock levels and raw material availability.</p>
                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a href="/Bom/Index" class="ib-tile h-100">
                <div class="tile-icon"><i class="bi bi-layers"></i></div>
                <div class="tile-content">
                    <h4>Master BOM View</h4>
                    <p>Full access to Bill of Materials for all active articles.</p>
                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a href="/Article/Index" class="ib-tile h-100">
                <div class="tile-icon"><i class="bi bi-search"></i></div>
                <div class="tile-content">
                    <h4>Article Search</h4>
                    <p>Lookup technical specs and shoe models across departments.</p>
                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a href="/Dashboard/Index" class="ib-tile h-100">
                <div class="tile-icon"><i class="bi bi-cpu"></i></div>
                <div class="tile-content">
                    <h4>Production Tracking</h4>
                    <p>Live tracking of factory floor status and order progress.</p>
                </div>
            </a>
        </div>

        <div class="col-md-6">
            <a href="/SampleOrder/Index" class="ib-tile h-100">
                <div class="tile-icon"><i class="bi bi-box-seam"></i></div>
                <div class="tile-content">
                    <h4>Sample Tracking</h4>
                    <p>Monitor the lifecycle of new sample orders and approvals.</p>
                </div>
            </a>
        </div>

