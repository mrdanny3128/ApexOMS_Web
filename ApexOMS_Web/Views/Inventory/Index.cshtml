@model IEnumerable<ApexOMS_Web.Models.InventoryOrder> 
@* Only show this button if the user is NOT in the IB department *@
@if (Context.Session.GetString("UserRole") != "IB")
{
    <a href="/InventoryController.cs/Create" class="btn btn-primary">+ Add New</a>
}


<div class="container-fluid mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between">
            <h4 class="mb-0">👟 Apex Production Inventory</h4>
            <span class="badge bg-light text-dark">Records: @Model.Count()</span>
        </div>
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-primary"><i class="bi bi-box-seam"></i> Inventory Orders</h2>
                <a href="/Inventory/Create" class="btn btn-success fw-bold">+ Add New Order</a>
            </div>
            <table class="table table-bordered table-hover">
                <thead class="table-secondary">
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Style Name</th>
                        <th>Color</th>
                        <th>Qty</th>
                        <th>Status</th>
                        <th>Receive Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.order_id</td>
                            <td>@item.cust_name</td>
                            <td>@item.style_name</td>
                            <td>@item.part_color</td>
                            <td>@item.totalqty?.ToString("N0")</td>
                            <td>
                                @if (item.order_status == 1)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Closed</span>
                                }
                            </td>
                            <td>@item.order_receive_date?.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>