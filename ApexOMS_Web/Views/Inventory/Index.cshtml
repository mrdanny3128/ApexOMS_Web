@model IEnumerable<ApexOMS_Web.Models.InventoryOrder>

<style>
    /* Professional Header & Search bar alignment */
    .dataTables_filter {
        display: flex;
        justify-content: center;
        margin-bottom: 2rem;
    }

        .dataTables_filter input {
            width: 450px !important;
            border-radius: 25px !important;
            padding: 12px 25px !important;
            border: 2px solid #95F0A5 !important; /* Apex Primary Blue */
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.1) !important;
            outline: none;
            transition: 0.3s ease-in-out;
        }

            .dataTables_filter input:focus {
                width: 500px !important;
                box-shadow: 0 6px 15px rgba(13, 110, 253, 0.2) !important;
            }

    /* Table styling */
    .inventory-card {
        border-radius: 15px;
        overflow: hidden;
    }

    #inventoryTable thead th {
        background-color: #C5F1C5;
        color: #333;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #dee2e6;
    }

    .qty-font {
        font-family: 'Courier New', Courier, monospace;
        font-weight: bold;
        color: #2c3e50;
    }

    .page-item.active .page-link {
        background-color: #39E357 !important;
        border-color: #39E357 !important;
    }

    .page-link {
        color: #ff5733;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-success fw-bold mb-0">
                <i class="bi bi-box-seam me-2">Inventory Orders</i>
            </h2>
            <p class="text-muted small">Total Active Inventory Records: <span class="badge bg-success">@Model.Count()</span></p>
        </div>

        @if (Context.Session.GetString("UserRole") != "IB")
        {
            <a href="/Inventory/Create" class="btn btn-success px-4 py-2 fw-bold shadow-sm">
                <i class="bi bi-plus-lg me-1 fw-bold">+Add New Order</i>
            </a>
        }
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
        </div>
    }

    <div class="card inventory-card shadow-sm border-0">
        <div class="card-body p-4">
            <table id="inventoryTable" class="table table-hover table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Style Name</th>
                        <th>Color</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-center">Status</th>
                        <th>Receive Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-success">#@item.order_id</td>
                            <td>@item.cust_name</td>
                            <td>@item.style_name</td>
                            <td>
                                <span class="badge rounded-pill border text-dark bg-light">
                                    @item.part_color
                                </span>
                            </td>
                            <td class="text-center qty-font">@item.totalqty?.ToString("N0")</td>
                            <td class="text-center">
                                @if (item.order_status == "1")
                                {
                                    <span class="badge bg-warning text-dark px-3 rounded-pill">
                                        <i class="bi bi-hourglass-split me-1"></i> Pending
                                    </span>
                                }
                                else if (item.order_status == "2")
                                {
                                    <span class="badge bg-success px-3 rounded-pill">
                                        <i class="bi bi-check2-all me-1"></i> Approved
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger px-3 rounded-pill">
                                        <i class="bi bi-x-circle me-1"></i> Closed
                                    </span>
                                }
                            </td>
                            <td class="text-muted">
                                <i class="bi bi-calendar3 me-1"></i>@item.order_receive_date?.ToString("dd MMM yyyy")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#inventoryTable').DataTable({
                "dom": '<"top"f>rt<"bottom"p><"clear">', // Position Search (f) at top center, Pagination (p) at bottom
                "paging": true,
                "pageLength": 15,
                "searching": true,
                "ordering": true,
                "info": false,
                "autoWidth": false,
                "responsive": true,
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search by Order ID, Style, or Color..."
                }
            });
        });
    </script>
}