<form action="/Inventory/Create" method="post">
    <div class="mb-3">
        <label class="form-label fw-bold text-muted">Order ID</label>
        <input type="text" class="form-control bg-light" value="Auto-Generated" readonly />
        <small class="text-muted">A random ID will be assigned upon saving.</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Customer Name</label>
        <input type="text" name="cust_name" class="form-control" placeholder="Enter Customer" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Style Name</label>
        <input type="text" name="style_name" class="form-control" placeholder="e.g. Apex Runner" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Part Color</label>
        <input type="text" name="part_color" class="form-control" placeholder="e.g. Black/Red" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Status</label>
        @* <input type="number" name="order_status" class="form-control" required /> *@
        <select name="order_status" class="form-select">
            <option value="1">Pending</option>
            <option value="2">Approved</option>
            <option value="0">Rejected</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Total Quantity</label>
        <input type="number" name="totalqty" class="form-control" required />
    </div>

    <div class="d-flex justify-content-between">
        <a href="/Inventory/Index" class="btn btn-secondary">Cancel</a>
        <button type="submit" class="btn btn-success px-5">Save Production Order</button>
    </div>
</form>