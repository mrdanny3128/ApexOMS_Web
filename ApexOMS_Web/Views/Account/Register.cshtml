@model ApexOMS_Web.Models.User
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>ID Registration - Apex OMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            /* 1. Set the background image ( professional warehouse view ) */
            background-image: url('https://theprestige.global/wp-content/uploads/2025/02/apex-event.png');
            /* 2. Ensure the image covers the whole screen */
            background-size: cover;
            /* 3. Center the image on the page */
            background-position: center;
            /* 4. Keep the image in place when scrolling */
            background-repeat: no-repeat;
            background-attachment: fixed;
            /* 5. Center the login card vertically and horizontally */
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* 6. Style the login card for better visibility */
        .login-card {
            background-color: rgba(255, 255, 255, 0.65); /* White with a little transparency */
            border-radius: 15px;
            box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.3); /* Strong shadow for depth */
            width: 400px;
            padding: 40px;
        }
    </style>
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-4 card shadow p-4">
                <h3 class="text-center text-success">ID Registration</h3>
                <hr />
                <form asp-action="Register" method="post">
                    <div class="mb-3">
                        <label>User ID</label>
                        <input name="user_id" class="form-control" placeholder="e.g. apex_101" required />
                    </div>
                    <div class="mb-3">
                        <label>Full Name</label>
                        <input name="user_name" class="form-control" placeholder="Enter name" required />
                    </div>
                    <div class="mb-3">
                        <label>E-Mail</label>
                        <input name="user_email" class="form-control" placeholder="Enter Email" required />
                    </div>
                    <div class="mb-3">
                        <label>Password</label>
                        <input type="password" name="user_pass" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label>Role</label>
                        <input type="role" name="Role" class="form-control" required />
                    </div>
                    <button type="submit" class="btn btn-success w-100">Create Account</button>
                    <div class="mt-3 text-center">
                        <a href="/Account/Login" class="text-decoration-none">Already have an ID? Login</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>