@model RegisterViewModel
@{
    Layout = null; // Keeping this null since you are providing the full HTML structure here
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ID Registration - Apex OMS</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background-image: url('../images/bg5.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .registration-container {
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 550px;
            padding: 2.5rem;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .form-control:focus {
            border-color: #ffc107;
            box-shadow: 0 0 0 0.25rem rgba(255, 193, 7, 0.25);
        }

        .cursor-pointer {
            cursor: pointer;
        }
    </style>
</head>
<body>
    @* FIX: The opening body tag must be here *@

    <div class="registration-container">
        <div class="glass-card">
            <div class="text-center mb-4">
                <img src="~/images/apex_logo.png" style="width:100px;" class="mb-2" />
                <h3 class="fw-bold text-dark">CREATE ACCOUNT</h3>
                <p class="text-muted small">Apex Order Management System</p>
            </div>

            <form asp-action="REGISTER" method="post" id="regForm">
                <div class="row">
                    <div class="form-floating mb-3">
                        <div class="form-floating">
                            <input asp-for="user_id" class="form-control" placeholder="ID" required />
                            <label asp-for="user_id"><i class="bi bi-person-badge me-2"></i>User ID</label>
                        </div>
                    </div>
                    <div class="form-floating mb-3">
                        <div class="form-floating">
                            <input asp-for="user_name" class="form-control" placeholder="Name" required />
                            <label asp-for="user_name"><i class="bi bi-person me-2"></i>Full Name</label>
                        </div>
                    </div>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="user_email" type="email" class="form-control" placeholder="Email" required />
                    <label asp-for="user_email"><i class="bi bi-envelope me-2"></i>Email Address</label>
                </div>

                <div class="form-floating mb-3">
                    <select asp-for="Role" class="form-select" required>
                        <option value="" disabled selected>Select Department</option>
                        <option value="SuperAdmin">Administrator</option>
                        <option value="DesignLab">Design Lab</option>
                        <option value="IB">International Business</option>
                    </select>
                  
                </div>

                <div class="form-floating mb-3 position-relative">
                    <input asp-for="user_pass" type="password" id="pass" class="form-control" placeholder="Password" required />
                    <label asp-for="user_pass"><i class="bi bi-lock me-2"></i>Password</label>
                    <i class="bi bi-eye position-absolute top-50 end-0 translate-middle-y me-3 cursor-pointer text-muted" id="togglePass"></i>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm" required />
                    <label asp-for="ConfirmPassword"><i class="bi bi-check2-circle me-2"></i>Confirm Password</label>
                </div>

                <button type="submit" class="btn btn-warning w-100 py-3 fw-bold rounded-3 shadow-sm" id="submitBtn">
                    REGISTER USER
                </button>

                <div class="text-center mt-4">
                    <a href="/Account/Login" class="text-decoration-none small text-secondary">
                        Already Registered? <span class="text-primary fw-bolder">LOGIN HERE</span>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Toggle Password Visibility
        document.getElementById('togglePass').addEventListener('click', function () {
            const passInput = document.getElementById('pass');
            const type = passInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passInput.setAttribute('type', type);
            this.classList.toggle('bi-eye');
            this.classList.toggle('bi-eye-slash');
        });

        // Loading state on submit
        document.getElementById('regForm').addEventListener('submit', function () {
            const btn = document.getElementById('submitBtn');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';
            btn.classList.add('disabled');
        });
    </script>
</body> @* FIX: The closing body tag must be here *@
</html>