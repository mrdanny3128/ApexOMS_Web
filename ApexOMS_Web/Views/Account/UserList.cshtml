@model IEnumerable<ApexOMS_Web.Models.User>

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-danger text-white p-3">
            <h4 class="mb-0"><i class="bi bi-people"></i> Pending & Existing Users</h4>
        </div>
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>User ID</th>
                        <th>Name</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@user.user_id</strong></td>
                            <td>@user.user_name</td>
                            <td><span class="badge bg-info text-dark">@user.Role</span></td>
                            <td>
                                @if (user.status == 0)
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                            </td>
                            <td>
                                <form asp-action="ApproveUser" method="post" class="row g-2">
                                    <input type="hidden" name="id" value="@user.sl" />
                                    <div class="col-auto">
                                        <select name="role" class="form-select form-select-sm">
                                            <option value="IB">IB Dept</option>
                                            <option value="DesignLab">Design Lab</option>
                                            <option value="SuperAdmin">Super Admin</option>
                                        </select>
                                    </div>
                                    <div class="col-auto">
                                        <button type="submit" class="btn btn-sm btn-danger">Update & Approve</button>
                                    </div>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>