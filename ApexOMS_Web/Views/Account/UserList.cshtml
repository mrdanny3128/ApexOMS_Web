@model IEnumerable<ApexOMS_Web.Models.User>

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-danger text-white p-3">
            <h4 class="mb-0"><i class="bi bi-people"></i> Pending & Existing Users</h4>
        </div>
        <div class="card-body">
        
            <table class="table table-hover align-middle">
                <thead class="bg-light">
                    <tr>
                        <th>User ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Expected Role</th>
                        <th>Role Status</th>
                        <th>Assign New Role</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.user_id</td>
                            <td>@item.user_name</td>

                            <td>@item.user_email</td>

                            <td>
                                <span class="badge bg-info text-dark">@item.Role</span>
                            </td>

                            

                            <td>
                                @if (item.status == 1)
                                {
                                    <span class="badge bg-success"><i class="bi bi-patch-check"></i> Approved</span>
                                }
                                else if (item.status == 2)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-slash-circle"></i> Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Pending</span>
                                }
                            </td>

                            <td>
                                <select class="form-select form-select-sm" id="role-@item.sl">
                                    <option value="SuperAdmin" selected="@(item.Role == "SuperAdmin")">Super Admin</option>
                                    <option value="DesignLab" selected="@(item.Role == "DesignLab")">Design Lab</option>
                                    <option value="IB" selected="@(item.Role == "IB")">IB Dept</option>
                                    
                                </select>
                            </td>

                           
                            <td>
                                <div class="btn-group">
                                    <button class="btn btn-danger btn-sm px-3" onclick="updateUser(@item.sl, 'Approved')">
                                        <i class="bi bi-check-circle"></i> Approve
                                    </button>
                                    <button class="btn btn-outline-dark btn-sm px-3" onclick="updateUser(@item.sl, 'Rejected')">
                                        <i class="bi bi-x-circle"></i> Reject
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


<script>
    function updateUser(id, targetStatus) {
        const roleDropdown = document.getElementById('role-' + id);
        if (!roleDropdown) {
            console.error("Could not find dropdown for ID:", id);
            return;
        }

        const newRole = roleDropdown.value;

        // Create the data object - ensure names match C# EXACTLY
        const payload = {
            sl: parseInt(id),
            Role: newRole,
            status: targetStatus
        };

        console.log("Sending Data:", payload); // Debugging: Check your browser console (F12)

        fetch('/Account/ApproveUser', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (response.ok) {
                alert("Done! User is now " + targetStatus);
                location.reload();
            } else {
                response.text().then(text => alert("Error from server: " + text));
            }
        })
        .catch(error => {
            console.error("Network Error:", error);
            alert("Network error. Check console.");
        });
    }
</script>