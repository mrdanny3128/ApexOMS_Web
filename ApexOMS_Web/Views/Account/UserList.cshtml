@* @model IEnumerable<ApexOMS_Web.Models.User>

<div class="container mt-5">
    <div class="card shadow border-0">
        <div class="card-header bg-danger text-white p-3">
            <h4 class="mb-0"><i class="bi bi-people"></i> Pending & Existing Users</h4>
        </div>
        <div class="card-body">
        
            <table class="table table-hover align-middle">
                <thead class="bg-light">
                    <tr>
                        <th>User ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Expected Role</th>
                        <th>Role Status</th>
                        <th>Assign New Role</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.user_id</td>
                            <td>@item.user_name</td>

                            <td>@item.user_email</td>

                            <td>
                                <span class="badge bg-info text-dark">@item.Role</span>
                            </td>

                            

                            <td>
                                @if (item.status == 1)
                                {
                                    <span class="badge bg-success"><i class="bi bi-patch-check"></i> Approved</span>
                                }
                                else if (item.status == 2)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-slash-circle"></i> Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Pending</span>
                                }
                            </td>

                            <td>
                                <select class="form-select form-select-sm" id="role-@item.sl">
                                    <option value="SuperAdmin" selected="@(item.Role == "SuperAdmin")">Super Admin</option>
                                    <option value="DesignLab" selected="@(item.Role == "DesignLab")">Design Lab</option>
                                    <option value="IB" selected="@(item.Role == "IB")">IB Dept</option>
                                    
                                </select>
                            </td>

                           
                            <td>
                                <div class="btn-group">
                                    <button class="btn btn-danger btn-sm px-3" onclick="updateUser(@item.sl, 'Approved')">
                                        <i class="bi bi-check-circle"></i> Approve
                                    </button>
                                    <button class="btn btn-outline-dark btn-sm px-3" onclick="updateUser(@item.sl, 'Rejected')">
                                        <i class="bi bi-x-circle"></i> Reject
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


<script>
    function updateUser(id, targetStatus) {
        const roleDropdown = document.getElementById('role-' + id);
        if (!roleDropdown) {
            console.error("Could not find dropdown for ID:", id);
            return;
        }

        const newRole = roleDropdown.value;

        // Create the data object - ensure names match C# EXACTLY
        const payload = {
            sl: parseInt(id),
            Role: newRole,
            status: targetStatus
        };

        console.log("Sending Data:", payload); // Debugging: Check your browser console (F12)

        fetch('/Account/ApproveUser', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (response.ok) {
                alert("Done! User is now " + targetStatus);
                location.reload();
            } else {
                response.text().then(text => alert("Error from server: " + text));
            }
        })
        .catch(error => {
            console.error("Network Error:", error);
            alert("Network error. Check console.");
        });
    }
</script>




@model IEnumerable<ApexOMS_Web.Models.User>

<div class="container-fluid mt-5 px-4">
    <div class="card shadow border-0">
        <div class="card-header bg-danger text-white p-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-people"></i> Pending & Existing Users</h4>
            <span class="badge bg-white text-danger">Total Users: @Model.Count()</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">User ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Current Role</th>
                        <th>Role Status</th>
                        <th>Assign New Role</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-bold text-dark">@item.user_id</td>
                            <td>@item.user_name</td>
                            <td>@item.user_email</td>
                            <td><span class="badge bg-info text-dark">@item.Role</span></td>
                            <td>
                                @if (item.status == 1)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Approved</span>
                                }
                                else if (item.status == 2)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Pending</span>
                                }
                            </td>
                            <td>
                                <select class="form-select form-select-sm w-75" id="role-@item.sl">
                                    <option value="SuperAdmin" selected="@(item.Role == "SuperAdmin")">Super Admin</option>
                                    <option value="DesignLab" selected="@(item.Role == "DesignLab")">Design Lab</option>
                                    <option value="IB" selected="@(item.Role == "IB")">IB Dept</option>
                                </select>
                            </td>
                            <td class="text-center">
                                @if (item.status == 0)
                                {
                                    <div class="btn-group shadow-sm">
                                        <button class="btn btn-success btn-sm px-3" onclick="processUser(@item.sl, 'Approved')">Approve</button>
                                        <button class="btn btn-outline-danger btn-sm px-3" onclick="processUser(@item.sl, 'Rejected')">Reject</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-primary btn-sm px-4" onclick="openEditModal('@item.sl', '@item.user_name', '@item.Role', '@(item.status == 1 ? "Approved" : "Rejected")', '@item.user_id')">
                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-person-gear me-2"></i>Edit User Access</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="edit-sl" />

                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small text-uppercase">User Name</label>
                    <input type="text" id="edit-name" class="form-control bg-light border-0 fw-bold" readonly />
                </div>

                <!-- ADDED: User ID Field -->
                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small text-uppercase">User ID</label>
                    <input type="text" id="edit-userid" class="form-control bg-light border-0" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small text-uppercase">Assign System Role</label>
                    <select id="edit-role" class="form-select border-primary">
                        <option value="SuperAdmin">Super Admin</option>
                        <option value="DesignLab">Design Lab</option>
                        <option value="IB">IB Dept</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-muted small text-uppercase">Account Status</label>
                    <select id="edit-status" class="form-select">
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4 shadow-sm" onclick="saveEdit()">Save Changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
