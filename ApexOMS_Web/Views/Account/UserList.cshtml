@section Scripts {
    <script>
        function processUser(id, targetStatus) {
            const roleDropdown = document.getElementById('role-' + id);
            if (!roleDropdown) return;

            const payload = {
                sl: parseInt(id),
                Role: roleDropdown.value,
                status: targetStatus
            };

            performUpdate(payload, "User status updated to " + targetStatus);
        }

        /**
         * FIX 2: Added 'userid' as an argument to the function definition
         */
        function openEditModal(sl, name, role, currentStatus, userid) {
            document.getElementById('edit-sl').value = sl;
            document.getElementById('edit-name').value = name;
            document.getElementById('edit-role').value = role;
            document.getElementById('edit-userid').value = userid; // This will now work
            document.getElementById('edit-status').value = currentStatus;

            const myModal = new bootstrap.Modal(document.getElementById('editUserModal'));
            myModal.show();
        }

        function saveEdit() {
            const payload = {
                sl: parseInt(document.getElementById('edit-sl').value),
                Role: document.getElementById('edit-role').value,
                status: document.getElementById('edit-status').value
            };

            performUpdate(payload, "User settings updated successfully.");
        }

        function performUpdate(payload, successMsg) {
            fetch('/Account/ApproveUser', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(response => {
                if (response.ok) {
                    alert(successMsg);
                    location.reload();
                } else {
                    alert("Server error. Check database constraints.");
                }
            })
            .catch(err => console.error("Fetch Error:", err));
        }
    </script>
