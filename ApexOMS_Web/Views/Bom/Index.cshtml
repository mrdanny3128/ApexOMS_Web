@model IEnumerable<ApexOMS_Web.Models.Bom>


<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold"><i class="bi bi-list-check"></i> Bill of Materials (BOM)</h2>
        @if (Context.Session.GetString("UserRole") != "IB")
        {
            <a href="/Bom/Create" class="btn btn-dark">+ New BOM Entry</a>
        }
        
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>BOM No</th>
                        <th>Sales Part</th>
                        <th>Last</th>
                        <th>Element</th>
                        <th>Material Description</th>
                        <th>Quantity</th>
                        <th>Finish Type</th>
                        <th>Unit Of Measures</th>
                        <th>Rate</th>
                        <th>Entry Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.BOM_NO</td>
                            <td>@item.APEX_SALES_PART</td>
                            <td>@item.LAST</td> 
                            <td>@item.ELEMENT</td>
                            <td>@item.MATERIALDESC</td>
                            <td>@item.QUANTITY</td>
                            <td>@item.finish_type</td>
                            <td>@item.UOM</td>
                            <td>@item.RATE?.ToString("C")</td>
                            <td>@item.CREATEDATE?.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>