@model IEnumerable<ApexOMS_Web.Models.ArticleLast>
@* Only show this button if the user is NOT in the IB department *@
@if (Context.Session.GetString("UserRole") != "IB")
{
    <a href="/ArticleLast.cs/Create" class="btn btn-primary">+ Add New</a>
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold"><i class="bi bi-layers-half"></i> Article & Last Master</h2>
        <a href="/Article/Create" class="btn btn-success px-4">+ Add New Article</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Sales Part</th>
                        <th>Last</th>
                        <th>Style</th>
                        <th>Gender</th>
                        <th>Season</th>
                        <th>Status</th>
                        <th>Entry Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="fw-bold">@item.apex_sales_part</span></td>
                            <td>@item.Last</td>
                            <td>@item.shoe_style</td>
                            <td>@item.gender</td>
                            <td>@item.season (@item.season_year)</td>
                            <td>
                                @if (item.status == 1)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>@item.entry_date?.ToString("yyyy-MM-dd HH:mm")</td>     
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>