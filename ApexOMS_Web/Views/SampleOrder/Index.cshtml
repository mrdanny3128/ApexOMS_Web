@using Microsoft.AspNetCore.Http
@model IEnumerable<ApexOMS_Web.Models.SampleOrder>

<style>
    /* Professional Search Bar Centering */
    .dataTables_filter {
        display: flex;
        justify-content: center;
        margin-bottom: 2rem;
    }

        .dataTables_filter input {
            width: 450px !important;
            border-radius: 25px !important;
            padding: 12px 25px !important;
            border: 2px solid #0d6efd !important;
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.1) !important;
            outline: none;
            transition: 0.3s ease-in-out;
        }

            .dataTables_filter input:focus {
                width: 500px !important;
                box-shadow: 0 6px 15px rgba(13, 110, 253, 0.2) !important;
            }

    /* Table & Card Refinement */
    .sample-card {
        border-radius: 15px;
        overflow: hidden;
    }

    #sampleTable thead th {
        background-color: #BAE1F5;
        text-transform: uppercase;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.5px;
        color: #495057; 
        
    }

    .order-no {
        color: #0d6efd;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
</style>

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary fw-bold mb-0">
                <i class="bi bi-calendar-check me-2">Sample Development Orders</i>
            </h2>
            <p class="text-muted small">Manage and track prototype requests</p>
        </div>

        @if (Context.Session.GetString("UserRole") != "IB")
        {
            <a href="/SampleOrder/Create" class="btn btn-primary fw-bold px-4 shadow-sm">
                <i class="bi bi-plus-lg me-2">+Add New Sample</i>
            </a>
        }
    </div>

    <div class="card sample-card shadow-sm border-0">
        <div class="card-body p-4">
            <table id="sampleTable" class="table table-hover table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Order No</th>
                        <th>Customer</th>
                        <th>Article</th>
                        <th>Pairs</th>
                        <th>Status</th>
                        <th>Delivery Date</th>
                        <th>Approval</th>
                        <th>Picture</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="order-no fw-bold">@item.sample_order_no</td>
                            <td>@item.cust_name</td>
                            <td><span class="text-secondary small">@item.apex_sales_part</span></td>
                            <td class="fw-bold">@item.pair</td>
                           
                            <td>
                                @if (item.sample_status == "In Progress")
                                {
                                    <span class="badge rounded-pill bg-secondary text-white">
                                        <i class="bi bi-tag me-1"></i>In Progress
                                    </span>
                                }
                                else if (item.sample_status == "Completed")
                                {
                                    <span class="badge rounded-pill bg-info text-dark">
                                        <i class="bi bi-tag me-1"></i>Completed
                                    </span>
                                }
                                else if (item.sample_status == "On Hold")
                                {
                                    <span class="badge rounded-pill bg-warning text-dark">
                                        <i class="bi bi-tag me-1"></i>On Hold
                                    </span>
                                }
                            </td>
                            <td>
                                <i class="bi bi-calendar-event me-1 text-muted"></i>
                                @item.delivery_date?.ToString("dd MMM yyyy")
                            </td>
                            <td>
                                @if (item.approval == "Approved")
                                {
                                    <span class="badge bg-success px-3 rounded-pill shadow-sm">
                                        <i class="bi bi-check-circle me-1"></i> Approved
                                    </span>
                                }
                                else if (item.approval == "Pending")
                                {
                                    <span class="badge bg-warning text-dark px-3 rounded-pill shadow-sm">
                                        <i class="bi bi-check-circle me-1"></i> Pending
                                    </span>
                                }
                                else if (item.approval == "Rejected")
                                {
                                    <span class="badge bg-danger px-3 rounded-pill shadow-sm">
                                        <i class="bi bi-x-circle me-1"></i> Rejected
                                    </span>
                                }
                            </td> @* Fixed unclosed TD from original code *@
                            <td>
                                @if (!string.IsNullOrEmpty(item.image_path))
                                {
                                    <img src="@item.image_path" class="img-thumbnail" style="width:50px; height:50px; object-fit:cover;" />
                                }
                                else
                                {
                                    <span class="text-muted small">No Image</span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.sl" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    <i class="bi bi-pencil-square me-1"></i>Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#sampleTable').DataTable({
                "dom": '<"top"f>rt<"bottom"p><"clear">',
                "paging": true,
                "searching": true,
                "ordering": true,
                "info": false,
                "autoWidth": false,
                "responsive": true,
                "language": {
                    "search": "",
                    "searchPlaceholder": "Search Here..."
                }
            });
        });
    </script>
}